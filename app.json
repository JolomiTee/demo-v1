{
	"expo": {
		"name": "demo-v1",
		"slug": "demo-v1",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "demo-v1",
		"userInterfaceStyle": "automatic",
		//  "newArchEnabled": true,
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/icon.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			// "edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.jolomitee.spotlight"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"@clerk/expo",
			"expo-secure-store",
			"expo-web-browser",
			"expo-font",
			"expo-image",
			"expo-status-bar",
			[
				"expo-navigation-bar",
				{
					"enforceContrast": true,
					"hidden": false,
					"style": "light"
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "fdcba342-60e8-48a5-9b44-31028b49c98d"
			}
		}
	}
}
